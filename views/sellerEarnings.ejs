<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Earnings' %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; }
    body { background: #f5f6fa; min-height: 100vh; }
    .container { max-width: 1200px; margin: 0 auto; padding: 20px; }
    .page-header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 30px; border-radius: 12px; margin-bottom: 25px; }
    .page-header h1 { font-size: 28px; margin-bottom: 8px; }
    .page-header p { opacity: 0.9; font-size: 14px; }
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 25px; }
    .stat-card { background: white; padding: 25px; border-radius: 12px; box-shadow: 0 2px 15px rgba(0,0,0,0.06); position: relative; }
    .stat-card .icon { font-size: 28px; margin-bottom: 10px; }
    .stat-card .number { font-size: 26px; font-weight: 700; color: #333; }
    .stat-card .label { font-size: 12px; color: #888; margin-top: 5px; text-transform: uppercase; }
    .stat-card .sub { font-size: 12px; color: #aaa; margin-top: 3px; }
    .stat-card.available { border-top: 4px solid #27ae60; }
    .stat-card.pending { border-top: 4px solid #f39c12; }
    .stat-card.earned { border-top: 4px solid #667eea; }
    .stat-card.fee { border-top: 4px solid #e74c3c; }
    .section { background: white; border-radius: 12px; padding: 25px; margin-bottom: 25px; box-shadow: 0 2px 15px rgba(0,0,0,0.06); }
    .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .section-header h2 { font-size: 18px; color: #333; }
    .payout-form { background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%); padding: 25px; border-radius: 12px; margin-bottom: 25px; }
    .payout-form h3 { font-size: 18px; margin-bottom: 15px; color: #333; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 15px; }
    @media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }
    .form-group label { display: block; font-size: 13px; color: #555; margin-bottom: 6px; font-weight: 500; }
    .form-group input, .form-group select { width: 100%; padding: 12px 15px; border: 1px solid #ddd; border-radius: 8px; font-size: 14px; }
    .form-group input:focus, .form-group select:focus { outline: none; border-color: #667eea; }
    .submit-btn { padding: 12px 30px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 8px; font-size: 15px; font-weight: 600; cursor: pointer; }
    .submit-btn:hover { opacity: 0.9; }
    .submit-btn:disabled { background: #ccc; cursor: not-allowed; }
    .min-note { font-size: 12px; color: #888; margin-top: 8px; }
    .min-note strong { color: #e74c3c; }
    .history-table { width: 100%; border-collapse: collapse; }
    .history-table th { text-align: left; padding: 12px; font-size: 12px; color: #888; text-transform: uppercase; border-bottom: 2px solid #f0f0f0; }
    .history-table td { padding: 12px; border-bottom: 1px solid #f5f5f5; }
    .history-table tr:hover { background: #fafbfc; }
    .status-badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 600; }
    .status-pending { background: #fff3cd; color: #856404; }
    .status-completed { background: #d4edda; color: #155724; }
    .status-cancelled { background: #f8d7da; color: #721c24; }
    .status-credit { background: #d4edda; color: #155724; }
    .status-debit { background: #f8d7da; color: #721c24; }
    .payout-card { background: #f8f9fa; padding: 15px; border-radius: 10px; margin-bottom: 10px; border-left: 4px solid #667eea; }
    .payout-card.pending { border-left-color: #f39c12; }
    .payout-card.approved { border-left-color: #27ae60; }
    .payout-card.rejected { border-left-color: #e74c3c; }
    .payout-card .amount { font-size: 20px; font-weight: 700; color: #333; }
    .payout-card .details { font-size: 13px; color: #666; margin-top: 5px; }
    .payout-card .status { margin-top: 8px; }
    .info-box { background: #e8f4fd; border-left: 4px solid #3498db; padding: 15px 20px; border-radius: 8px; margin-bottom: 20px; font-size: 14px; color: #333; }
    .info-box strong { color: #3498db; }
    .empty-state { text-align: center; padding: 50px 20px; color: #888; }
    .empty-state .icon { font-size: 50px; margin-bottom: 15px; }
    .chart-bar { display: flex; align-items: flex-end; gap: 8px; height: 150px; padding: 20px 0; }
    .chart-bar-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8px; }
    .chart-bar-item .bar { width: 100%; background: linear-gradient(180deg, #667eea 0%, #764ba2 100%); border-radius: 6px 6px 0 0; min-height: 5px; transition: height 0.3s; }
    .chart-bar-item .label { font-size: 11px; color: #888; }
    .chart-bar-item .value { font-size: 12px; font-weight: 600; color: #667eea; }
  </style>
</head>
<body>
  <div class="container">
    <div class="page-header">
      <h1>💰 My Earnings</h1>
      <p>Track your earnings, request payouts, and manage your wallet.</p>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
      <div class="stat-card available">
        <div class="icon">💵</div>
        <div class="number">₹<%= (stats.availableBalance || 0).toLocaleString('en-IN') %></div>
        <div class="label">Available Balance</div>
        <div class="sub">Ready to withdraw</div>
      </div>
      <div class="stat-card pending">
        <div class="icon">⏳</div>
        <div class="number">₹<%= (stats.pendingAmount || 0).toLocaleString('en-IN') %></div>
        <div class="label">Pending Balance</div>
        <div class="sub">In return period</div>
      </div>
      <div class="stat-card earned">
        <div class="icon">📈</div>
        <div class="number">₹<%= (stats.netEarnings || 0).toLocaleString('en-IN') %></div>
        <div class="label">Total Earned</div>
        <div class="sub">Lifetime earnings</div>
      </div>
      <div class="stat-card fee">
        <div class="icon">🏷️</div>
        <div class="number"><%= stats.platformFeeRate || 10 %>%</div>
        <div class="label">Platform Fee</div>
        <div class="sub">Per transaction</div>
      </div>
    </div>

    <!-- Info Box -->
    <div class="info-box">
      <strong>💡 How it works:</strong> After a customer receives their order, the return policy period (7 days) must end before funds are released to your wallet. You can then request a withdrawal. Minimum withdrawal is <strong>₹1,000</strong>.
    </div>

    <!-- Payout Request Form -->
    <div class="payout-form">
      <h3>📤 Request Payout</h3>
      <form id="payoutForm">
        <div class="form-row">
          <div class="form-group">
            <label>Amount to Withdraw (₹)</label>
            <input type="number" name="amount" id="payoutAmount" min="1000" step="100" placeholder="Minimum ₹1,000" required>
          </div>
          <div class="form-group">
            <label>Payout Method</label>
            <select name="method" id="payoutMethod">
              <option value="bank_transfer" <%= payoutSettings.preferredMethod === 'bank_transfer' ? 'selected' : '' %>>Bank Transfer</option>
              <option value="upi" <%= payoutSettings.preferredMethod === 'upi' ? 'selected' : '' %>>UPI</option>
            </select>
          </div>
        </div>
        <div id="bankFields" class="form-row">
          <div class="form-group">
            <label>Account Holder Name</label>
            <input type="text" name="accountName" value="<%= payoutSettings.bankAccountName || '' %>" placeholder="Name as per bank">
          </div>
          <div class="form-group">
            <label>Bank Account Number</label>
            <input type="text" name="accountNumber" value="<%= payoutSettings.bankAccountNumber || '' %>" placeholder="Enter account number">
          </div>
          <div class="form-group">
            <label>IFSC Code</label>
            <input type="text" name="ifsc" value="<%= payoutSettings.bankIfsc || '' %>" placeholder="e.g., SBIN0001234">
          </div>
          <div class="form-group">
            <label>Bank Name</label>
            <input type="text" name="bankName" value="<%= payoutSettings.bankName || '' %>" placeholder="e.g., State Bank of India">
          </div>
        </div>
        <div id="upiFields" class="form-row" style="display:none;">
          <div class="form-group">
            <label>UPI ID</label>
            <input type="text" name="upiId" value="<%= payoutSettings.upiId || '' %>" placeholder="e.g., yourname@upi">
          </div>
        </div>
        <button type="submit" class="submit-btn" id="submitBtn">Request Payout</button>
        <div class="min-note">Minimum payout amount is <strong>₹1,000</strong>. Available balance: <strong>₹<%= (stats.availableBalance || 0).toLocaleString('en-IN') %></strong></div>
      </form>
    </div>

    <!-- Pending Payouts -->
    <% if (pendingPayouts && pendingPayouts.length > 0) { %>
    <div class="section">
      <div class="section-header"><h2>⏳ Pending Payout Requests</h2></div>
      <% pendingPayouts.forEach(payout => { %>
      <div class="payout-card pending">
        <div class="amount">₹<%= payout.amount.toLocaleString('en-IN') %></div>
        <div class="details">
          Requested on <%= new Date(payout.createdAt).toLocaleDateString('en-IN') %> | 
          Method: <%= payout.payoutMethod?.type === 'upi' ? 'UPI' : 'Bank Transfer' %>
          <% if (payout.payoutMethod?.bankAccountNumber) { %> | A/C: ****<%= payout.payoutMethod.bankAccountNumber.slice(-4) %><% } %>
          <% if (payout.payoutMethod?.upiId) { %> | UPI: <%= payout.payoutMethod.upiId %><% } %>
        </div>
        <div class="status"><span class="status-badge status-pending">Pending Admin Approval</span></div>
      </div>
      <% }) %>
    </div>
    <% } %>

    <!-- Earnings History Chart -->
    <div class="section">
      <div class="section-header"><h2>📊 Monthly Earnings</h2></div>
      <% if (earningsHistory && earningsHistory.length > 0) { %>
      <% const maxVal = Math.max(...earningsHistory.map(e => e.amount || 0), 1); %>
      <div class="chart-bar">
        <% earningsHistory.forEach(item => { %>
        <div class="chart-bar-item">
          <div class="value">₹<%= (item.amount || 0).toLocaleString('en-IN') %></div>
          <div class="bar" style="height: <%= ((item.amount || 0) / maxVal * 120) %>px;"></div>
          <div class="label"><%= item.month %></div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div class="empty-state">
        <div class="icon">📊</div>
        <p>No earnings data yet. Start selling to see your monthly earnings!</p>
      </div>
      <% } %>
    </div>

    <!-- Transaction History -->
    <div class="section">
      <div class="section-header"><h2>📋 Transaction History</h2></div>
      <% if (wallet && wallet.transactions && wallet.transactions.length > 0) { %>
      <table class="history-table">
        <thead>
          <tr><th>Date</th><th>Type</th><th>Description</th><th>Amount</th><th>Status</th></tr>
        </thead>
        <tbody>
          <% wallet.transactions.slice().reverse().forEach(tx => { %>
          <tr>
            <td><%= new Date(tx.createdAt).toLocaleDateString('en-IN') %></td>
            <td>
              <span class="status-badge status-<%= tx.type === 'credit' ? 'credit' : tx.type === 'debit' || tx.type === 'payout_approved' ? 'debit' : 'pending' %>">
                <%= tx.type.replace('_', ' ').toUpperCase() %>
              </span>
            </td>
            <td><%= tx.description %></td>
            <td style="font-weight:600;color:<%= tx.type === 'credit' ? '#27ae60' : '#e74c3c' %>">
              <%= tx.type === 'credit' ? '+' : '-' %>₹<%= tx.amount.toLocaleString('en-IN') %>
            </td>
            <td><span class="status-badge status-<%= tx.status %>"><%= tx.status.toUpperCase() %></span></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } else { %>
      <div class="empty-state">
        <div class="icon">📋</div>
        <p>No transactions yet. Your earnings will appear here!</p>
      </div>
      <% } %>
    </div>
  </div>

  <script>
    const methodSelect = document.getElementById('payoutMethod');
    const bankFields = document.getElementById('bankFields');
    const upiFields = document.getElementById('upiFields');
    methodSelect.addEventListener('change', function() {
      if (this.value === 'upi') { bankFields.style.display = 'none'; upiFields.style.display = 'grid'; }
      else { bankFields.style.display = 'grid'; upiFields.style.display = 'none'; }
    });
    methodSelect.dispatchEvent(new Event('change'));

    document.getElementById('payoutForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const btn = document.getElementById('submitBtn');
      btn.disabled = true; btn.textContent = 'Processing...';
      const formData = new FormData(this);
      const data = {
        amount: formData.get('amount'),
        method: formData.get('method'),
        accountDetails: {
          bankAccountName: formData.get('accountName'),
          bankAccountNumber: formData.get('accountNumber'),
          bankIfsc: formData.get('ifsc'),
          bankName: formData.get('bankName'),
          upiId: formData.get('upiId')
        }
      };
      try {
        const res = await fetch('/seller/earnings/payout', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const result = await res.json();
        if (result.success) { alert('✅ ' + result.message); location.reload(); }
        else { alert('❌ ' + result.message); }
      } catch (err) { alert('❌ Error: ' + err.message); }
      finally { btn.disabled = false; btn.textContent = 'Request Payout'; }
    });
  </script>
</body>
</html>
