<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; }
    body { background: #f5f6fa; min-height: 100vh; }
    .container { max-width: 1400px; margin: 0 auto; padding: 20px; }
    .page-header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 30px; border-radius: 12px; margin-bottom: 25px; }
    .page-header h1 { font-size: 28px; margin-bottom: 8px; }
    .page-header p { opacity: 0.9; font-size: 14px; }
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 25px; }
    .stat-card { background: white; padding: 25px; border-radius: 12px; box-shadow: 0 2px 15px rgba(0,0,0,0.06); position: relative; overflow: hidden; }
    .stat-card::before { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%; }
    .stat-card.products::before { background: #667eea; }
    .stat-card.revenue::before { background: #27ae60; }
    .stat-card.orders::before { background: #f39c12; }
    .stat-card.wallet::before { background: #9b59b6; }
    .stat-card .icon { font-size: 32px; margin-bottom: 12px; }
    .stat-card .number { font-size: 28px; font-weight: 700; color: #333; }
    .stat-card .label { font-size: 13px; color: #888; margin-top: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
    .stat-card .sub { font-size: 12px; color: #aaa; margin-top: 4px; }
    .wallet-card { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 20px rgba(102,126,234,0.3); margin-bottom: 25px; }
    .wallet-card .wallet-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .wallet-card .wallet-title { font-size: 16px; opacity: 0.9; }
    .wallet-card .wallet-icon { font-size: 28px; }
    .wallet-card .balance { font-size: 36px; font-weight: 700; margin-bottom: 5px; }
    .wallet-card .balance-label { font-size: 13px; opacity: 0.8; margin-bottom: 20px; }
    .wallet-card .wallet-row { display: flex; gap: 30px; flex-wrap: wrap; }
    .wallet-card .wallet-item .value { font-size: 20px; font-weight: 600; }
    .wallet-card .wallet-item .label { font-size: 12px; opacity: 0.7; margin-top: 2px; }
    .wallet-card .withdraw-btn { margin-top: 20px; padding: 10px 24px; background: white; color: #667eea; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 14px; text-decoration: none; display: inline-block; }
    .wallet-card .withdraw-btn:hover { background: #f0f0f0; }
    .section { background: white; border-radius: 12px; padding: 25px; margin-bottom: 25px; box-shadow: 0 2px 15px rgba(0,0,0,0.06); }
    .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .section-header h2 { font-size: 18px; color: #333; }
    .section-header a { color: #667eea; text-decoration: none; font-size: 14px; font-weight: 500; }
    .products-table { width: 100%; border-collapse: collapse; }
    .products-table th { text-align: left; padding: 12px; font-size: 12px; color: #888; text-transform: uppercase; border-bottom: 2px solid #f0f0f0; }
    .products-table td { padding: 12px; border-bottom: 1px solid #f5f5f5; vertical-align: middle; }
    .products-table tr:hover { background: #fafbfc; }
    .product-cell { display: flex; align-items: center; gap: 12px; }
    .product-cell img { width: 45px; height: 45px; object-fit: cover; border-radius: 8px; }
    .product-cell .title { font-weight: 600; font-size: 14px; color: #333; }
    .product-cell .meta { font-size: 12px; color: #888; margin-top: 2px; }
    .stock-badge { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 11px; font-weight: 600; }
    .stock-in { background: #d4edda; color: #155724; }
    .stock-low { background: #fff3cd; color: #856404; }
    .stock-out { background: #f8d7da; color: #721c24; }
    .top-selling { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; }
    .top-item { background: #f8f9fa; padding: 15px; border-radius: 10px; text-align: center; }
    .top-item img { width: 80px; height: 80px; object-fit: cover; border-radius: 10px; margin-bottom: 10px; }
    .top-item .title { font-size: 13px; font-weight: 600; color: #333; margin-bottom: 4px; }
    .top-item .sales { font-size: 12px; color: #888; }
    .top-item .revenue { font-size: 14px; color: #27ae60; font-weight: 600; margin-top: 4px; }
    .alert-bar { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; padding: 15px 25px; border-radius: 10px; margin-bottom: 20px; display: flex; align-items: center; gap: 15px; }
    .alert-bar .alert-icon { font-size: 24px; }
    .alert-bar .alert-text { flex: 1; }
    .alert-bar .alert-text strong { display: block; margin-bottom: 2px; }
    .alert-bar .alert-text span { font-size: 13px; opacity: 0.9; }
    .alert-bar .alert-btn { padding: 8px 20px; background: white; color: #f5576c; border: none; border-radius: 6px; font-weight: 600; cursor: pointer; font-size: 13px; text-decoration: none; }
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 25px; }
    @media (max-width: 900px) { .two-col { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <div class="container">
    <div class="page-header">
      <h1>👋 Welcome back, <%= seller.businessName || seller.fullName %>!</h1>
      <p>Here's what's happening with your store today.</p>
    </div>

    <!-- New Orders Alert -->
    <% if (newOrdersCount > 0) { %>
    <div class="alert-bar">
      <div class="alert-icon">🔔</div>
      <div class="alert-text">
        <strong>You have <%= newOrdersCount %> new order<%= newOrdersCount > 1 ? 's' : '' %>!</strong>
        <span>Please review and confirm them to start processing.</span>
      </div>
      <a href="/seller/orders?status=pending" class="alert-btn">View Orders</a>
    </div>
    <% } %>

    <!-- Stats Grid -->
    <div class="stats-grid">
      <div class="stat-card products">
        <div class="icon">📦</div>
        <div class="number"><%= stats.totalProducts || 0 %></div>
        <div class="label">Total Products</div>
        <div class="sub"><%= stats.activeProducts || 0 %> active</div>
      </div>
      <div class="stat-card revenue">
        <div class="icon">💰</div>
        <div class="number">₹<%= (stats.totalRevenue || 0).toLocaleString('en-IN') %></div>
        <div class="label">Total Revenue</div>
        <div class="sub">Lifetime earnings</div>
      </div>
      <div class="stat-card orders">
        <div class="icon">🛒</div>
        <div class="number"><%= newOrdersCount || 0 %></div>
        <div class="label">New Orders</div>
        <div class="sub">Awaiting confirmation</div>
      </div>
      <div class="stat-card wallet">
        <div class="icon">👛</div>
        <div class="number">₹<%= (wallet.availableBalance || 0).toLocaleString('en-IN') %></div>
        <div class="label">Wallet Balance</div>
        <div class="sub">Available for withdrawal</div>
      </div>
    </div>

    <!-- Wallet Card -->
    <div class="wallet-card">
      <div class="wallet-header">
        <div>
          <div class="wallet-title">My Wallet</div>
          <div class="balance">₹<%= (wallet.availableBalance || 0).toLocaleString('en-IN') %></div>
          <div class="balance-label">Available for withdrawal</div>
        </div>
        <div class="wallet-icon">💳</div>
      </div>
      <div class="wallet-row">
        <div class="wallet-item">
          <div class="value">₹<%= (wallet.pendingBalance || 0).toLocaleString('en-IN') %></div>
          <div class="label">Pending (in return period)</div>
        </div>
        <div class="wallet-item">
          <div class="value">₹<%= (wallet.totalEarned || 0).toLocaleString('en-IN') %></div>
          <div class="label">Total Lifetime Earnings</div>
        </div>
        <div class="wallet-item">
          <div class="value">₹<%= (wallet.totalWithdrawn || 0).toLocaleString('en-IN') %></div>
          <div class="label">Total Withdrawn</div>
        </div>
      </div>
      <a href="/seller/earnings"><button class="withdraw-btn">Withdraw Funds →</button></a>
    </div>

    <div class="two-col">
      <!-- Recent Products -->
      <div class="section">
        <div class="section-header">
          <h2>📦 Recent Products</h2>
          <a href="/products/seller/list">View All</a>
        </div>
        <% if (recentProducts && recentProducts.length > 0) { %>
        <table class="products-table">
          <thead>
            <tr><th>Product</th><th>Price</th><th>Stock</th><th>Sales</th></tr>
          </thead>
          <tbody>
            <% recentProducts.forEach(product => { %>
            <tr>
              <td>
                <div class="product-cell">
                  <img src="<%= product.thumbnail || '/images/placeholder-product.jpg' %>" alt="<%= product.title %>">
                  <div>
                    <div class="title"><%= product.title %></div>
                    <div class="meta"><%= product.category %> | <%= product.productType %></div>
                  </div>
                </div>
              </td>
              <td style="font-weight:600;">₹<%= product.sellingPrice.toLocaleString('en-IN') %></td>
              <td>
                <span class="stock-badge stock-<%= product.stockStatus === 'In Stock' ? 'in' : product.stockStatus === 'Low Stock' ? 'low' : 'out' %>">
                  <%= product.stockStatus %>
                </span>
              </td>
              <td><%= product.totalSales || 0 %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } else { %>
        <div style="text-align:center;padding:40px;color:#888;">
          <div style="font-size:40px;margin-bottom:10px;">📭</div>
          <p>No products yet. <a href="/products/seller/add" style="color:#667eea;">Add your first product</a></p>
        </div>
        <% } %>
      </div>

      <!-- Top Selling -->
      <div class="section">
        <div class="section-header">
          <h2>🏆 Top Selling Products</h2>
          <a href="/products/seller/list?sort=popular">View All</a>
        </div>
        <% if (topSelling && topSelling.length > 0) { %>
        <div class="top-selling">
          <% topSelling.forEach(product => { %>
          <div class="top-item">
            <img src="<%= product.thumbnail || '/images/placeholder-product.jpg' %>" alt="<%= product.title %>">
            <div class="title"><%= product.title %></div>
            <div class="sales"><%= product.totalSales || 0 %> sold</div>
            <div class="revenue">₹<%= (product.totalRevenue || 0).toLocaleString('en-IN') %></div>
          </div>
          <% }) %>
        </div>
        <% } else { %>
        <div style="text-align:center;padding:40px;color:#888;">
          <div style="font-size:40px;margin-bottom:10px;">📊</div>
          <p>No sales data yet. Start selling to see your top products!</p>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Low Stock Alerts -->
    <% if (stats.lowStockProducts > 0 || stats.outOfStockProducts > 0) { %>
    <div class="section" style="border-left: 4px solid #e74c3c;">
      <div class="section-header">
        <h2 style="color:#e74c3c;">⚠️ Stock Alerts</h2>
        <a href="/products/seller/stock-alert">Manage Stock</a>
      </div>
      <div style="display:flex;gap:30px;">
        <% if (stats.outOfStockProducts > 0) { %>
        <div>
          <div style="font-size:24px;font-weight:700;color:#e74c3c;"><%= stats.outOfStockProducts %></div>
          <div style="font-size:13px;color:#888;">Products out of stock</div>
        </div>
        <% } %>
        <% if (stats.lowStockProducts > 0) { %>
        <div>
          <div style="font-size:24px;font-weight:700;color:#f39c12;"><%= stats.lowStockProducts %></div>
          <div style="font-size:13px;color:#888;">Products low on stock</div>
        </div>
        <% } %>
      </div>
    </div>
    <% } %>
  </div>
</body>
</html>
